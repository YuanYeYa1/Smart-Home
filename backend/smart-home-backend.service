[Unit]
Description=ESP32 Smart Home Backend Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/smart-home/backend
ExecStart=/usr/bin/python3 /root/smart-home/backend/main.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
